# RWA Readiness Registry — Contract deployment environment variables
#
# Copy this file to .env and fill in real values.
# This file is safe to commit (no secrets).
# NEVER commit the actual .env file.

# Avalanche Fuji RPC endpoint.
# Public endpoint: https://api.avax-test.network/ext/bc/C/rpc
# Use a dedicated provider URL for reliability in production.
FUJI_RPC_URL=

# Private key of the deployer wallet (without 0x prefix).
# Fund this wallet with Fuji test AVAX from https://faucet.avax.network/
# NEVER share this key or commit it to version control.
DEPLOYER_PRIVATE_KEY=

# Snowtrace API key for contract verification on Fuji explorer.
# Obtain at: https://snowtrace.io/myapikey
# Leave blank to skip verification.
FUJI_EXPLORER_API_KEY=
