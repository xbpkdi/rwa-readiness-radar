# RWA Readiness Radar — Frontend environment variables
#
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real addresses or secrets.
#
# VITE_ variables are safe for browser use.
# Do NOT add DEPLOYER_PRIVATE_KEY or FUJI_EXPLORER_API_KEY here — those are
# contract deployment secrets and must only be placed in contracts/.env

# Deployed RWAReadinessRegistry contract address on Avalanche Fuji.
# Leave blank until the contract is deployed.
VITE_RWA_REGISTRY_ADDRESS=

# Public Fuji RPC URL for browser-side reads (no private key needed).
# Defaults to the public Avalanche Fuji RPC if not set.
VITE_FUJI_RPC_URL=
